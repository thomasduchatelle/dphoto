{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}",
        "X-MCP-Toolsets": "actions,code_security,dependabot,git,pull_requests,security_advisories"
      }
    }
  }
}
